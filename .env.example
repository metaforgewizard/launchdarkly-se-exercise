# =============================================================================
# Repo-root .env file — read by docker-compose at the top level.
# Copy this to .env (same directory) and fill in the three values below.
# .env is git-ignored.
# =============================================================================
#
# WHICH KEY GOES WHERE:
#   - VITE_LD_CLIENT_SIDE_ID  → the React web app (Parts 1, 2, EC1)
#   - LD_SDK_KEY              → the AI Configs server (Extra Credit 2)
#   - ANTHROPIC_API_KEY       → the AI Configs server (Extra Credit 2)
#
# The two LaunchDarkly values are different keys with different security
# properties. Don't mix them up — see the per-subproject READMEs for details.
# =============================================================================

# ---- LaunchDarkly: client-side ID (web app) ----
# Find this in LaunchDarkly:
#   Account settings → Projects → (your project) → Environments →
#   "Client-side ID" column.
# Safe to expose in browser code (the SDK shipping it to the browser is by design).
# Vite reads this at BUILD time and bakes it into the JS bundle. If you change
# this value, you must rebuild: `docker compose up --build`.
VITE_LD_CLIENT_SIDE_ID=

# ---- LaunchDarkly: server-side SDK key (AI server) ----
# Same place in the LaunchDarkly UI as above, but the "SDK key" column.
# This is a SECRET — never commit it, never put it in client-side code.
LD_SDK_KEY=

# ---- Anthropic API key (AI server) ----
# Get one at https://console.anthropic.com → API keys → Create key.
# This is a SECRET. The repo author may share a pre-funded, spend-capped key
# out-of-band for evaluation purposes; otherwise create your own.
ANTHROPIC_API_KEY=
