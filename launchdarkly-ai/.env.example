# LaunchDarkly server-side SDK key.
# Find this in your LD project at: Project settings → Environments → SDK key (NOT client-side ID).
# This is a SECRET — never commit it. Different from the VITE_LD_CLIENT_SIDE_ID used by the main project.
LD_SDK_KEY=

# Anthropic API key.
# Get one at: https://console.anthropic.com/ → API keys → Create key.
# A few dollars of credit will run thousands of demo turns; claude-haiku-4-5 calls cost fractions of a penny.
ANTHROPIC_API_KEY=

# Port for the local Express server. Defaults to 3001 if not set.
# (The main Vite project runs on 5173, so 3001 keeps them clear of each other.)
PORT=3001
