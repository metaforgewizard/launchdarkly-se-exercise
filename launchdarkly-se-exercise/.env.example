# Copy this file to .env.local and fill in your LaunchDarkly client-side ID.
# Do NOT commit .env.local. The .gitignore already excludes it.

# Your LaunchDarkly environment's Client-side ID.
# Find this in LaunchDarkly: Account Settings -> Projects -> [Your Project] -> Environments.
# This is the "Client-side ID" — NOT the SDK key, NOT the mobile key.
# Client-side IDs are safe to expose in browser code.
VITE_LD_CLIENT_SIDE_ID=
